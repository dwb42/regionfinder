FROM node:22-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_REGIONFINDER_API_BASE_URL=https://regionfinder.b42.io
ENV VITE_REGIONFINDER_API_BASE_URL=$VITE_REGIONFINDER_API_BASE_URL
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY infra/nginx.conf /etc/nginx/conf.d/default.conf
