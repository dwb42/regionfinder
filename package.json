{
  "name": "regionfinder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-local.mjs",
    "dev:frontend": "vite",
    "dev:api": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "db:migrate": "tsx scripts/migrate-db.ts",
    "pipeline:validate": "python3 -m pipeline.validate_sources",
    "pipeline:import:synthetic": "python3 -m pipeline.import_gtfs --source fixtures/gtfs/synthetic --source-key synthetic_gtfs",
    "pipeline:compute": "python3 -m pipeline.compute_metrics --snapshot fixture-synthetic-2026-07 --profile regular_tue_thu --origin hamburg-hbf",
    "py:install": "python3 -m venv .venv && .venv/bin/pip install -r pipeline/requirements.txt",
    "data:discover": ".venv/bin/python -m pipeline.production_sources discover",
    "data:download": ".venv/bin/python -m pipeline.production_sources download",
    "data:validate": ".venv/bin/python -m pipeline.production_sources validate",
    "data:bootstrap:production": ".venv/bin/python -m pipeline.production_bootstrap",
    "pipeline:import:production": ".venv/bin/python -m pipeline.production_import",
    "rail:reconstruct": ".venv/bin/python -m pipeline.rail_network",
    "boundaries:import": ".venv/bin/python -m pipeline.admin_boundaries",
    "schools:import": ".venv/bin/python -m pipeline.schools",
    "places:import": ".venv/bin/python -m pipeline.places",
    "places:research:ferienhoefe": ".venv/bin/python -m pipeline.ferienhof_research",
    "places:research:ferienhoefe:landreise": "node scripts/research-landreise-ferienhoefe.mjs",
    "routing:build:r5": ".venv/bin/python -m pipeline.routing_r5",
    "routing:build:motis": ".venv/bin/python -m pipeline.routing_motis",
    "metrics:compute:production": ".venv/bin/python -m pipeline.production_metrics",
    "verify:production": ".venv/bin/python -m pipeline.verify_production",
    "check": "npm run build && npm run test && npm run lint",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.5",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
